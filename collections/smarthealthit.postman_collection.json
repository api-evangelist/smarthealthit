{
  "info": {
    "name": "SMART Health IT Sandbox FHIR APIs",
    "description": "Free public SMART on FHIR sandboxes operated by SMART Health IT (Boston Children's Hospital / Harvard Medical School). Includes the open FHIR R4 server at https://r4.smarthealthit.org (no auth, synthetic patient records), the SMART App Launcher OAuth endpoints at https://launch.smarthealthit.org/v/r4/auth, and the reference Bulk Data server at https://bulk-data.smarthealthit.org/fhir (SMART Backend Services JWT auth). Synthetic data only - never send real PHI.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "openBaseUrl", "value": "https://r4.smarthealthit.org", "type": "string" },
    { "key": "launcherBaseUrl", "value": "https://launch.smarthealthit.org/v/r4", "type": "string" },
    { "key": "bulkBaseUrl", "value": "https://bulk-data.smarthealthit.org/fhir", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Open FHIR R4 Sandbox",
      "item": [
        {
          "name": "Retrieve the CapabilityStatement",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{openBaseUrl}}/metadata", "host": ["{{openBaseUrl}}"], "path": ["metadata"] },
            "description": "Returns the FHIR R4 CapabilityStatement for the open sandbox (60+ resource types, full REST interactions, no auth)."
          }
        },
        {
          "name": "Search patients",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{openBaseUrl}}/Patient?_count=10",
              "host": ["{{openBaseUrl}}"],
              "path": ["Patient"],
              "query": [
                { "key": "_count", "value": "10" },
                { "key": "name", "value": "", "disabled": true },
                { "key": "birthdate", "value": "", "disabled": true },
                { "key": "gender", "value": "", "disabled": true }
              ]
            },
            "description": "Searches synthetic Patient resources; returns a searchset Bundle."
          }
        },
        {
          "name": "Read a patient",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{openBaseUrl}}/Patient/:id", "host": ["{{openBaseUrl}}"], "path": ["Patient", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Reads a single synthetic Patient resource by logical id."
          }
        },
        {
          "name": "Search observations for a patient",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{openBaseUrl}}/Observation?patient=&category=vital-signs",
              "host": ["{{openBaseUrl}}"],
              "path": ["Observation"],
              "query": [
                { "key": "patient", "value": "" },
                { "key": "category", "value": "vital-signs" }
              ]
            },
            "description": "Searches Observation resources (vitals, labs) scoped to a patient."
          }
        },
        {
          "name": "Search conditions for a patient",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{openBaseUrl}}/Condition?patient=",
              "host": ["{{openBaseUrl}}"],
              "path": ["Condition"],
              "query": [{ "key": "patient", "value": "" }]
            },
            "description": "Searches Condition resources (problems and diagnoses) for a patient."
          }
        },
        {
          "name": "Search medication requests for a patient",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{openBaseUrl}}/MedicationRequest?patient=",
              "host": ["{{openBaseUrl}}"],
              "path": ["MedicationRequest"],
              "query": [{ "key": "patient", "value": "" }]
            },
            "description": "Searches MedicationRequest resources (prescriptions) for a patient."
          }
        },
        {
          "name": "Search immunizations for a patient",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{openBaseUrl}}/Immunization?patient=",
              "host": ["{{openBaseUrl}}"],
              "path": ["Immunization"],
              "query": [{ "key": "patient", "value": "" }]
            },
            "description": "Searches Immunization resources (vaccination history) for a patient."
          }
        },
        {
          "name": "Search allergies for a patient",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{openBaseUrl}}/AllergyIntolerance?patient=",
              "host": ["{{openBaseUrl}}"],
              "path": ["AllergyIntolerance"],
              "query": [{ "key": "patient", "value": "" }]
            },
            "description": "Searches AllergyIntolerance resources for a patient."
          }
        }
      ]
    },
    {
      "name": "SMART App Launch (Launcher)",
      "item": [
        {
          "name": "Authorize (SMART App Launch)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{launcherBaseUrl}}/auth/authorize?response_type=code&client_id=my_app&redirect_uri=http://localhost:3000/callback&scope=launch/patient patient/*.read openid fhirUser&state=abc123&aud={{launcherBaseUrl}}/fhir",
              "host": ["{{launcherBaseUrl}}"],
              "path": ["auth", "authorize"],
              "query": [
                { "key": "response_type", "value": "code" },
                { "key": "client_id", "value": "my_app" },
                { "key": "redirect_uri", "value": "http://localhost:3000/callback" },
                { "key": "scope", "value": "launch/patient patient/*.read openid fhirUser" },
                { "key": "state", "value": "abc123" },
                { "key": "aud", "value": "{{launcherBaseUrl}}/fhir" }
              ]
            },
            "description": "OAuth 2.0 authorization endpoint (authorization code + PKCE). Best exercised in a browser; the sandbox requires no client registration."
          }
        },
        {
          "name": "Exchange code for token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "authorization_code" },
                { "key": "code", "value": "" },
                { "key": "redirect_uri", "value": "http://localhost:3000/callback" },
                { "key": "code_verifier", "value": "" },
                { "key": "client_id", "value": "my_app" }
              ]
            },
            "url": { "raw": "{{launcherBaseUrl}}/auth/token", "host": ["{{launcherBaseUrl}}"], "path": ["auth", "token"] },
            "description": "Exchanges an authorization code for an access token carrying SMART launch context (patient, encounter, fhirUser)."
          }
        },
        {
          "name": "Read protected CapabilityStatement",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{launcherBaseUrl}}/fhir/metadata", "host": ["{{launcherBaseUrl}}"], "path": ["fhir", "metadata"] },
            "description": "CapabilityStatement of the launcher's FHIR proxy; its security section advertises the OAuth2 SMART-on-FHIR authorize/token/introspect endpoints."
          }
        },
        {
          "name": "Read patient in context (protected)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{launcherBaseUrl}}/fhir/Patient/:id", "host": ["{{launcherBaseUrl}}"], "path": ["fhir", "Patient", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Reads the patient granted in launch context using the SMART access token."
          }
        }
      ]
    },
    {
      "name": "Bulk Data Export",
      "item": [
        {
          "name": "Start system-level $export",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/fhir+json" },
              { "key": "Prefer", "value": "respond-async" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{bulkBaseUrl}}/$export",
              "host": ["{{bulkBaseUrl}}"],
              "path": ["$export"],
              "query": [
                { "key": "_type", "value": "", "disabled": true },
                { "key": "_since", "value": "", "disabled": true }
              ]
            },
            "description": "Kicks off an async export of all resources; responds 202 with a Content-Location status URL to poll (honor Retry-After). Requires a SMART Backend Services token."
          }
        },
        {
          "name": "Start patient-level $export",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/fhir+json" },
              { "key": "Prefer", "value": "respond-async" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{bulkBaseUrl}}/Patient/$export", "host": ["{{bulkBaseUrl}}"], "path": ["Patient", "$export"] },
            "description": "Kicks off an async export of all data for all patients."
          }
        },
        {
          "name": "Start group-level $export",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/fhir+json" },
              { "key": "Prefer", "value": "respond-async" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{bulkBaseUrl}}/Group/:id/$export", "host": ["{{bulkBaseUrl}}"], "path": ["Group", ":id", "$export"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Kicks off an async export of all data for the patients in a Group."
          }
        }
      ]
    }
  ]
}
